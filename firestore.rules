rules_version = '2';

// 변화관리 의견 광장 — 완전 익명 정책 + 관리자 인증
//
// 정책:
//  - 모든 사용자(익명): topics·comments·config 읽기 가능
//  - 익명 사용자: 댓글 create만 가능 (content/department 검증 + 마감 전)
//  - Firebase Auth로 로그인한 사용자(=관리자): topics·config 모든 쓰기 + 댓글 삭제 가능
//  - 일반 사용자가 회원가입하는 페이지가 없으므로 로그인된 사용자 = 관리자
//    관리자 추가/삭제는 Firebase 콘솔 Authentication → Users 에서 수행

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ────────────────────────────────────
    function isAdmin() {
      return request.auth != null;
    }

    function isValidComment() {
      return request.resource.data.keys().hasAll(['content', 'department', 'createdAt'])
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 1500
          && request.resource.data.department is string
          && request.resource.data.department.size() > 0
          && request.resource.data.department.size() <= 40;
    }

    function isBeforeDue(topicId) {
      let topic = get(/databases/$(database)/documents/topics/$(topicId)).data;
      return topic.status == 'active'
          && (topic.dueAt == null || request.time < topic.dueAt);
    }

    // ── 주제 ─────────────────────────────────────────
    match /topics/{topicId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      // ── 댓글 (완전 익명) ──────────────────────────
      match /comments/{commentId} {
        allow read: if true;

        // 익명 사용자 등록: 검증 + 마감 전
        // 관리자: 무조건 가능
        allow create: if isAdmin()
                       || (isValidComment() && isBeforeDue(topicId));

        allow update: if false;            // 누구도 수정 불가
        allow delete: if isAdmin();        // 관리자만 회수 가능
      }
    }

    // ── 설정값 (departments, stopwords, sheets) ─────
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── 그 외 모두 차단 ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
