rules_version = '2';

// 변화관리 의견 광장 — 익명 게시 + 사번 비공개 정책
//
// 정책 (v3 2026-05-20):
//  - 모든 사용자(익명): topics 와 comments(공개 영역) 읽기 가능, config 일부만 읽기 가능
//  - 익명 사용자: comments create. 사번을 남긴 경우에만 commentsPrivate 도 create
//    (사번 미입력 시 완전 익명 — commentsPrivate 미생성. ipHash 등 다른 식별자도 저장하지 않음)
//  - commentsPrivate(사번)는 관리자만 read — 일반 사용자가 DevTools 로 직접 쿼리해도 차단
//  - Firebase Auth 로그인한 사용자(=관리자): topics·config 쓰기 + 댓글 양쪽 삭제 + commentsPrivate read
//  - 비밀번호는 사용자 작성 시 mandatory (passwordHash 필드 필수, sha-256 64자 hex)

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ────────────────────────────────────
    function isAdmin() {
      return request.auth != null;
    }

    function isValidComment() {
      return request.resource.data.keys().hasAll(['content', 'department', 'createdAt', 'passwordHash', 'isPrivate', 'status'])
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 1500
          && request.resource.data.department is string
          && request.resource.data.department.size() > 0
          && request.resource.data.department.size() <= 40
          && request.resource.data.passwordHash is string
          && request.resource.data.passwordHash.size() == 64
          && request.resource.data.isPrivate is bool
          && request.resource.data.status is string
          && request.resource.data.status in ['pending', 'received', 'forwarded'];
    }

    function isValidPrivate() {
      return request.resource.data.keys().hasOnly(['employeeId'])
          && request.resource.data.employeeId is string
          && request.resource.data.employeeId.matches('^[0-9]{7}$');
    }

    function isBeforeDue(topicId) {
      let topic = get(/databases/$(database)/documents/topics/$(topicId)).data;
      return topic.status == 'active'
          && (topic.dueAt == null || request.time < topic.dueAt);
    }

    // ── 주제 ─────────────────────────────────────────
    match /topics/{topicId} {
      allow read: if true;
      allow create, delete: if isAdmin();

      // update: 관리자는 모든 필드 가능.
      // 익명은 commentCount 단일 필드만 ±1 단위 변경 가능 (댓글 추가/삭제 동기화용).
      allow update: if isAdmin()
                     || (
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
                       && (request.resource.data.commentCount == resource.data.commentCount + 1
                           || request.resource.data.commentCount == resource.data.commentCount - 1)
                     );

      // ── 공개 댓글 (부문·내용·시간·passwordHash·isPrivate) ──────────
      // isPrivate=true 면 클라이언트가 비관리자 화면에서 본문을 가림 (집계에는 포함).
      match /comments/{commentId} {
        allow read: if true;

        allow create: if isAdmin()
                       || (isValidComment() && isBeforeDue(topicId));

        // 수정: 관리자 항상 가능. 작성자는 마감 전 + content 만 변경, 핵심 필드(passwordHash·department·createdAt·status) 보존.
        // editedAt 은 serverTimestamp 로만 설정 가능. 실제 비밀번호 검증은 클라이언트(v1 한계).
        // status 보존은 .get() 폴백 — status 필드 없는 구버전 댓글 수정도 허용.
        allow update: if isAdmin()
                       || (
                            request.resource.data.passwordHash == resource.data.passwordHash
                         && request.resource.data.department == resource.data.department
                         && request.resource.data.createdAt == resource.data.createdAt
                         && request.resource.data.isPrivate == resource.data.isPrivate
                         && request.resource.data.get('status', 'pending') == resource.data.get('status', 'pending')
                         && request.resource.data.content is string
                         && request.resource.data.content.size() > 0
                         && request.resource.data.content.size() <= 1500
                         && request.resource.data.editedAt == request.time
                         && request.resource.data.keys().hasOnly(['content', 'department', 'createdAt', 'passwordHash', 'editedAt', 'isPrivate', 'status'])
                         && isBeforeDue(topicId)
                       );

        // 삭제: 관리자 항상 가능, 작성자는 passwordHash 가 있는 댓글에 한해 허용
        // (실제 비밀번호 검증은 클라이언트에서 수행 — v1 한계, Cloud Function 으로 강화 권장)
        allow delete: if isAdmin()
                       || resource.data.keys().hasAny(['passwordHash']);
      }

      // ── 비공개 메타 (사번) — admin only read, 사번 입력 시에만 익명 create ──
      // 같은 commentId 로 comments 와 1:1 매칭. 일반 사용자는 read 불가.
      match /commentsPrivate/{commentId} {
        allow read: if isAdmin();
        allow update: if false;
        // 삭제: 관리자 항상 가능. 작성자가 본인 의견 삭제 후 cleanup 하는 경우는
        // 공개 댓글이 먼저 사라진 상태이므로 그때만 허용 (고아 메타 정리).
        allow delete: if isAdmin()
                       || !exists(/databases/$(database)/documents/topics/$(topicId)/comments/$(commentId));
        allow create: if isAdmin()
                       || (isValidPrivate() && isBeforeDue(topicId));
      }
    }

    // ── 설정값 (departments, stopwords, sheets) ─────
    // sheets 도큐먼트는 webhookUrl·sharedSecret 등 민감정보 포함 → 관리자만 read
    match /config/{docId} {
      allow read: if docId != "sheets" || isAdmin();
      allow write: if isAdmin();
    }

    // ── 그 외 모두 차단 ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
